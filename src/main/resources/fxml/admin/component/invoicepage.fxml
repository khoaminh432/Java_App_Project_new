<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!--
    InvoiceManagement.fxml
    ── Kích thước : 922 × 540 px (khớp layout gốc)
    ── Chức năng  : getAllInvoices · createInvoice · updateInvoice · deleteInvoice
                   getInvoicesByCustomer · getInvoicesByDateRange
                   getCurrentMonthInvoices · getTodayInvoices
                   markInvoiceAsPaid · cancelInvoice · updateInvoiceStatus
                   getTodayRevenue · getCurrentMonthRevenue · getCurrentYearRevenue
    ── Style      : khớp app My Coffee Management (nền xám nhạt, card xanh lá, bảng trắng)
-->
<AnchorPane
    fx:id="apInvoiceManagement"
    prefHeight="540.0"
    prefWidth="922.0"
    maxHeight="-Infinity" maxWidth="-Infinity"
    minHeight="-Infinity" minWidth="-Infinity"
    style="-fx-background-color: #e8ede8;"
    xmlns="http://javafx.com/javafx/21.0.1"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="my_app.controller.component.InvoiceController">

  <children>
    <VBox spacing="8.0"
        AnchorPane.topAnchor="8.0" AnchorPane.bottomAnchor="8.0"
        AnchorPane.leftAnchor="12.0" AnchorPane.rightAnchor="12.0">

      <!-- ══════════════════════════════════════════════════ -->
      <!--   ROW 1 – TOPBAR  (tiêu đề + tìm kiếm + Thêm)    -->
      <!-- ══════════════════════════════════════════════════ -->
      <HBox alignment="CENTER_LEFT" spacing="10.0" prefHeight="46.0" minHeight="46.0" maxHeight="46.0"
          style="-fx-background-color: white; -fx-background-radius: 25px;">
        <padding><Insets left="26.0" right="16.0"/></padding>

        <Label text="Quản Lý Hóa Đơn" HBox.hgrow="ALWAYS"
            style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2d2d2d;"/>

        <Separator opacity="0.0" HBox.hgrow="ALWAYS"/>

        <!-- Lọc trạng thái -->
        <ComboBox fx:id="cbStatusFilter" promptText="Trạng thái"
            prefWidth="130.0" prefHeight="30.0"
            style="-fx-background-color: #f4f4f4; -fx-border-color: #d0d8d0; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-font-size: 12px;"/>

        <!-- Tìm kiếm -->
        <HBox alignment="CENTER_LEFT" spacing="5.0"
            style="-fx-background-color: #f4f4f4; -fx-border-color: #d0d8d0; -fx-border-width: 1; -fx-border-radius: 20px; -fx-background-radius: 20px; -fx-padding: 5 12 5 12;">
          <Label text="🔍" style="-fx-font-size: 11px; -fx-text-fill: #999;"/>
          <TextField fx:id="tfSearchInvoice" promptText="Tìm Kiếm (ID Khách Hàng)"
              prefWidth="175.0"
              style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 12px; -fx-text-fill: #333; -fx-prompt-text-fill: #aaa;"/>
        </HBox>

        <!-- Nút Thêm -->
        <Button fx:id="btnAdd" text="+ Thêm"
            prefHeight="32.0" prefWidth="78.0"
            onAction="#handleAdd"
            style="-fx-background-color: #4a7c59; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8px; -fx-cursor: hand;"/>
      </HBox>

      <!-- ══════════════════════════════════════════════════ -->
      <!--   ROW 2 – BỘ LỌC NGÀY  (từ ngày → đến ngày)      -->
      <!-- ══════════════════════════════════════════════════ -->
      <HBox alignment="CENTER_LEFT" spacing="10.0" prefHeight="36.0" minHeight="36.0" maxHeight="36.0"
          style="-fx-background-color: white; -fx-background-radius: 18px;">
        <padding><Insets left="20.0" right="16.0"/></padding>

        <Label text="📅" style="-fx-font-size: 13px;"/>
        <Label text="Lọc theo ngày:"
            style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #555;"/>

        <DatePicker fx:id="dpFrom" promptText="Từ ngày"
            prefWidth="130.0" prefHeight="26.0"
            style="-fx-font-size: 11.5px;"/>
        <Label text="→" style="-fx-text-fill: #888; -fx-font-size: 13px;"/>
        <DatePicker fx:id="dpTo" promptText="Đến ngày"
            prefWidth="130.0" prefHeight="26.0"
            style="-fx-font-size: 11.5px;"/>

        <Button fx:id="btnFilterDate" text="Lọc"
            prefHeight="26.0" prefWidth="54.0"
            onAction="#handleFilterByDate"
            style="-fx-background-color: #5a8f6a; -fx-text-fill: white; -fx-font-size: 11.5px; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-cursor: hand;"/>

        <Button fx:id="btnToday" text="Hôm nay"
            prefHeight="26.0" prefWidth="72.0"
            onAction="#handleFilterToday"
            style="-fx-background-color: #e8f5e9; -fx-text-fill: #3a7a4a; -fx-font-size: 11.5px; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-border-color: #a5d6a7; -fx-border-radius: 6px; -fx-cursor: hand;"/>

        <Button fx:id="btnThisMonth" text="Tháng này"
            prefHeight="26.0" prefWidth="80.0"
            onAction="#handleFilterThisMonth"
            style="-fx-background-color: #e8f5e9; -fx-text-fill: #3a7a4a; -fx-font-size: 11.5px; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-border-color: #a5d6a7; -fx-border-radius: 6px; -fx-cursor: hand;"/>

        <Separator opacity="0.0" HBox.hgrow="ALWAYS"/>

        <Button fx:id="btnReset" text="↺ Tất cả"
            prefHeight="26.0" prefWidth="72.0"
            onAction="#handleReset"
            style="-fx-background-color: #f0f0f0; -fx-text-fill: #666; -fx-font-size: 11.5px; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-cursor: hand;"/>
      </HBox>

      <!-- ══════════════════════════════════════════════════ -->
      <!--   ROW 3 – STAT CARDS  (4 thẻ bằng nhau)          -->
      <!-- ══════════════════════════════════════════════════ -->
      <HBox spacing="10.0" minHeight="88.0" maxHeight="88.0">

        <!-- Card: Tổng Hóa Đơn -->
        <AnchorPane HBox.hgrow="ALWAYS"
            style="-fx-background-color: linear-gradient(to bottom right, #66bb6a, #43a047); -fx-background-radius: 18px;">
          <HBox AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <padding><Insets left="14.0" right="14.0" top="10.0" bottom="10.0"/></padding>
            <!-- Icon góc trái -->
            <VBox alignment="BOTTOM_LEFT" HBox.hgrow="NEVER">
              <Label text="🧾" style="-fx-font-size: 34px; -fx-opacity: 0.3;"/>
            </VBox>
            <!-- Số + nhãn góc phải -->
            <VBox alignment="TOP_RIGHT" HBox.hgrow="ALWAYS">
              <Label fx:id="lblTotalInvoices" text="0"
                  style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: white;"/>
              <Separator opacity="0.0" VBox.vgrow="ALWAYS"/>
              <Label text="Tổng Hóa Đơn"
                  style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.88);"/>
            </VBox>
          </HBox>
        </AnchorPane>

        <!-- Card: Doanh Thu Hôm Nay -->
        <AnchorPane HBox.hgrow="ALWAYS"
            style="-fx-background-color: linear-gradient(to bottom right, #66bb6a, #43a047); -fx-background-radius: 18px;">
          <HBox AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <padding><Insets left="14.0" right="14.0" top="10.0" bottom="10.0"/></padding>
            <VBox alignment="BOTTOM_LEFT" HBox.hgrow="NEVER">
              <Label text="💰" style="-fx-font-size: 34px; -fx-opacity: 0.3;"/>
            </VBox>
            <VBox alignment="TOP_RIGHT" HBox.hgrow="ALWAYS">
              <Label fx:id="lblTodayRevenue" text="0 ₫"
                  style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
              <Separator opacity="0.0" VBox.vgrow="ALWAYS"/>
              <Label text="Doanh Thu Hôm Nay"
                  style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.88);"/>
            </VBox>
          </HBox>
        </AnchorPane>

        <!-- Card: Doanh Thu Tháng -->
        <AnchorPane HBox.hgrow="ALWAYS"
            style="-fx-background-color: linear-gradient(to bottom right, #4caf50, #388e3c); -fx-background-radius: 18px;">
          <HBox AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <padding><Insets left="14.0" right="14.0" top="10.0" bottom="10.0"/></padding>
            <VBox alignment="BOTTOM_LEFT" HBox.hgrow="NEVER">
              <Label text="📈" style="-fx-font-size: 34px; -fx-opacity: 0.3;"/>
            </VBox>
            <VBox alignment="TOP_RIGHT" HBox.hgrow="ALWAYS">
              <Label fx:id="lblMonthRevenue" text="0 ₫"
                  style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
              <Separator opacity="0.0" VBox.vgrow="ALWAYS"/>
              <Label text="Doanh Thu Tháng"
                  style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.88);"/>
            </VBox>
          </HBox>
        </AnchorPane>

        <!-- Card: Doanh Thu Năm -->
        <AnchorPane HBox.hgrow="ALWAYS"
            style="-fx-background-color: linear-gradient(to bottom right, #4caf50, #388e3c); -fx-background-radius: 18px;">
          <HBox AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <padding><Insets left="14.0" right="14.0" top="10.0" bottom="10.0"/></padding>
            <VBox alignment="BOTTOM_LEFT" HBox.hgrow="NEVER">
              <Label text="📊" style="-fx-font-size: 34px; -fx-opacity: 0.3;"/>
            </VBox>
            <VBox alignment="TOP_RIGHT" HBox.hgrow="ALWAYS">
              <Label fx:id="lblYearRevenue" text="0 ₫"
                  style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
              <Separator opacity="0.0" VBox.vgrow="ALWAYS"/>
              <Label text="Doanh Thu Năm"
                  style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.88);"/>
            </VBox>
          </HBox>
        </AnchorPane>

      </HBox>

      <!-- ══════════════════════════════════════════════════ -->
      <!--   ROW 4 – BẢNG DỮ LIỆU                           -->
      <!-- ══════════════════════════════════════════════════ -->
      <AnchorPane VBox.vgrow="ALWAYS"
          style="-fx-background-color: white; -fx-background-radius: 12px;">
        <TableView fx:id="invoiceTable"
            AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
            AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
            stylesheets="@../../../css/stylecomponent.css"
            style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 12.5px;">
          <columns>
            <TableColumn fx:id="colId"          text="ID"          prefWidth="50.0"  minWidth="50.0"  maxWidth="60.0"/>
            <TableColumn fx:id="colCustomerId"  text="ID KH"       prefWidth="65.0"  minWidth="65.0"  maxWidth="80.0"/>
            <TableColumn fx:id="colEmployeeId"  text="ID NV"       prefWidth="65.0"  minWidth="65.0"  maxWidth="80.0"/>
            <TableColumn fx:id="colIssuedDate"  text="Ngày Xuất"   prefWidth="100.0" minWidth="90.0"/>
            <TableColumn fx:id="colTotalAmount" text="Tổng Tiền"   prefWidth="120.0" minWidth="100.0"/>
            <TableColumn fx:id="colStatus"      text="Tình Trạng"  prefWidth="90.0"  minWidth="90.0"/>
            <!-- Hành Động: 👁Xem · ✏Sửa · 🗑Xóa · ✓Thanh toán · ✕Hủy -->
            <TableColumn fx:id="colActions"     text="Hành Động"   prefWidth="220.0" minWidth="220.0"/>
          </columns>
          <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
          </columnResizePolicy>
        </TableView>
      </AnchorPane>

    </VBox>
  </children>
</AnchorPane>
