<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="apInvoiceManagement" 
            maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" 
            prefHeight="800.0" prefWidth="1200.0" styleClass="container-component" stylesheets="@../../../css/stylecomponent.css" 
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <BorderPane fx:id="bpContent" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="my_app.controller.InvoiceManagementController"
            prefHeight="800.0" prefWidth="1200.0"
            AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.bottomAnchor="0.0">
    
    <!-- Top: Title and Statistics -->
    <top>
        <VBox spacing="15" style="-fx-background-color: #2c3e50; -fx-padding: 20;">
            <!-- Title -->
            <Label text="QUẢN LÝ HÓA ĐƠN" textFill="white">
                <font>
                    <Font name="System Bold" size="24"/>
                </font>
            </Label>
            
            <!-- Statistics -->
            <HBox spacing="20" alignment="CENTER_LEFT">
                <VBox spacing="5" style="-fx-background-color: #3498db; -fx-padding: 15; -fx-background-radius: 5;">
                    <Label text="Tổng hóa đơn" textFill="white" style="-fx-font-size: 12;"/>
                    <Label fx:id="lblTotalInvoices" text="0" textFill="white">
                        <font>
                            <Font name="System Bold" size="20"/>
                        </font>
                    </Label>
                </VBox>
                
                <VBox spacing="5" style="-fx-background-color: #2ecc71; -fx-padding: 15; -fx-background-radius: 5;">
                    <Label text="Doanh thu hôm nay" textFill="white" style="-fx-font-size: 12;"/>
                    <Label fx:id="lblTodayRevenue" text="0 VND" textFill="white">
                        <font>
                            <Font name="System Bold" size="20"/>
                        </font>
                    </Label>
                </VBox>
                
                <VBox spacing="5" style="-fx-background-color: #e74c3c; -fx-padding: 15; -fx-background-radius: 5;">
                    <Label text="Doanh thu tháng này" textFill="white" style="-fx-font-size: 12;"/>
                    <Label fx:id="lblMonthRevenue" text="0 VND" textFill="white">
                        <font>
                            <Font name="System Bold" size="20"/>
                        </font>
                    </Label>
                </VBox>
                
                <VBox spacing="5" style="-fx-background-color: #f39c12; -fx-padding: 15; -fx-background-radius: 5;">
                    <Label text="Doanh thu năm nay" textFill="white" style="-fx-font-size: 12;"/>
                    <Label fx:id="lblYearRevenue" text="0 VND" textFill="white">
                        <font>
                            <Font name="System Bold" size="20"/>
                        </font>
                    </Label>
                </VBox>
            </HBox>
        </VBox>
    </top>
    
    <!-- Center: Main Content -->
    <center>
        <VBox spacing="15" style="-fx-padding: 20;">
            
            <!-- Search Section -->
            <VBox spacing="10" style="-fx-background-color: #ecf0f1; -fx-padding: 15; -fx-background-radius: 5;">
                <Label text="Tìm kiếm" style="-fx-font-weight: bold; -fx-font-size: 14;"/>
                
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <VBox spacing="5">
                        <Label text="ID Khách hàng:"/>
                        <TextField fx:id="txtSearchCustomerId" promptText="Nhập ID khách hàng" prefWidth="150"/>
                    </VBox>
                    
                    <VBox spacing="5">
                        <Label text="Từ ngày:"/>
                        <DatePicker fx:id="dpSearchFrom" prefWidth="150"/>
                    </VBox>
                    
                    <VBox spacing="5">
                        <Label text="Đến ngày:"/>
                        <DatePicker fx:id="dpSearchTo" prefWidth="150"/>
                    </VBox>
                    
                    <VBox spacing="5">
                        <Label text=" "/>
                        <HBox spacing="10">
                            <Button fx:id="btnSearch" text="Tìm kiếm" onAction="#handleSearch" 
                                    style="-fx-background-color: #3498db; -fx-text-fill: white;" prefWidth="100"/>
                            <Button fx:id="btnRefresh" text="Làm mới" onAction="#handleRefresh" 
                                    style="-fx-background-color: #95a5a6; -fx-text-fill: white;" prefWidth="100"/>
                        </HBox>
                    </VBox>
                </HBox>
            </VBox>
            
            <!-- Table -->
            <VBox VBox.vgrow="ALWAYS">
                <Label text="Danh sách hóa đơn" style="-fx-font-weight: bold; -fx-font-size: 14;">
                    <VBox.margin>
                        <Insets bottom="10"/>
                    </VBox.margin>
                </Label>
                
                <TableView fx:id="invoiceTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="colCustomerId" text="ID KH" prefWidth="80"/>
                        <TableColumn fx:id="colEmployeeId" text="ID NV" prefWidth="80"/>
                        <TableColumn fx:id="colIssuedDate" text="Ngày xuất" prefWidth="180"/>
                        <TableColumn fx:id="colTotalAmount" text="Tổng tiền" prefWidth="150"/>
                        <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="120"/>
                    </columns>
                </TableView>
            </VBox>
            
        </VBox>
    </center>
    
    <!-- Right: Form -->
    <right>
        <VBox spacing="15" style="-fx-background-color: #ecf0f1; -fx-padding: 20;" prefWidth="350">
            <Label text="Thông tin hóa đơn" style="-fx-font-weight: bold; -fx-font-size: 16;"/>
            
            <Separator/>
            
            <!-- Form Fields -->
            <VBox spacing="10">
                <Label text="ID Khách hàng: *"/>
                <TextField fx:id="txtCustomerId" promptText="Nhập ID khách hàng"/>
                
                <Label text="ID Nhân viên: *"/>
                <TextField fx:id="txtEmployeeId" promptText="Nhập ID nhân viên"/>
                
                <Label text="ID Đơn hàng:"/>
                <TextField fx:id="txtOrderId" promptText="Nhập ID đơn hàng"/>
                
                <Label text="ID Phương thức thanh toán:"/>
                <TextField fx:id="txtPaymentMethodId" promptText="Nhập ID phương thức"/>
                
                <Label text="Tổng tiền: *"/>
                <TextField fx:id="txtTotalAmount" promptText="Nhập tổng tiền"/>
                
                <Label text="Trạng thái:"/>
                <ComboBox fx:id="cmbStatus" prefWidth="Infinity"/>
                
                <Label text="Ngày xuất:"/>
                <DatePicker fx:id="dpIssuedDate" prefWidth="Infinity"/>
            </VBox>
            
            <Separator/>
            
            <!-- Action Buttons -->
            <VBox spacing="10">
                <Label text="Thao tác" style="-fx-font-weight: bold;"/>
                
                <Button fx:id="btnCreate" text="Tạo mới" onAction="#handleCreate" 
                        style="-fx-background-color: #2ecc71; -fx-text-fill: white;" 
                        prefWidth="Infinity" prefHeight="35">
                    <font>
                        <Font name="System Bold" size="12"/>
                    </font>
                </Button>
                
                <Button fx:id="btnUpdate" text="Cập nhật" onAction="#handleUpdate" 
                        style="-fx-background-color: #3498db; -fx-text-fill: white;" 
                        prefWidth="Infinity" prefHeight="35">
                    <font>
                        <Font name="System Bold" size="12"/>
                    </font>
                </Button>
                
                <Button fx:id="btnDelete" text="Xóa" onAction="#handleDelete" 
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white;" 
                        prefWidth="Infinity" prefHeight="35">
                    <font>
                        <Font name="System Bold" size="12"/>
                    </font>
                </Button>
                
                <Separator/>
                
                <Button fx:id="btnMarkPaid" text="Đánh dấu đã thanh toán" onAction="#handleMarkPaid" 
                        style="-fx-background-color: #27ae60; -fx-text-fill: white;" 
                        prefWidth="Infinity" prefHeight="35"/>
                
                <Button fx:id="btnCancel" text="Hủy hóa đơn" onAction="#handleCancelInvoice" 
                        style="-fx-background-color: #c0392b; -fx-text-fill: white;" 
                        prefWidth="Infinity" prefHeight="35"/>
                
                <Button fx:id="btnClear" text="Xóa form" onAction="#handleClear" 
                        style="-fx-background-color: #95a5a6; -fx-text-fill: white;" 
                        prefWidth="Infinity" prefHeight="35"/>
            </VBox>
            
        </VBox>
    </right>
    
        </BorderPane>
    </children>
</AnchorPane>
