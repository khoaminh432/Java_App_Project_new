<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane stylesheets="@../../css/styleLoginRegister.css" xmlns="http://javafx.com/javafx/21.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="your.package.LoginRegisterController">
    
    <VBox alignment="CENTER" spacing="20" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
        <padding>
            <Insets bottom="40" left="40" right="40" top="40" />
        </padding>
        
        <!-- Title -->
        <Label fx:id="titleLabel" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Welcome Back" />
        
        <!-- Username Field -->
        <TextField fx:id="usernameField" maxWidth="300" promptText="Username or Email" />
        
        <!-- Password Field -->
        <PasswordField fx:id="passwordField" maxWidth="300" promptText="Password" />
        
        <!-- Confirm Password Field (hidden by default) -->
        <PasswordField fx:id="confirmPasswordField" managed="false" maxWidth="300" promptText="Confirm Password" visible="false" />
        
        <!-- Login Button -->
        <Button fx:id="loginButton" maxWidth="300" text="Login" />
        
        <!-- Register Button (hidden by default) -->
        <Button fx:id="registerButton" managed="false" maxWidth="300" text="Register" visible="false" />
        
        <!-- Toggle Button -->
        <Button fx:id="toggleButton" style="-fx-background-color: transparent; -fx-text-fill: blue;" text="Don't have an account? Register" />
        
        <!-- Forgot Password -->
        <Hyperlink fx:id="forgotLink" text="Forgot Password?" />
        
    </VBox>
    
</AnchorPane>
