<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="your.package.controller.ProductController">
    
    <!-- Top - Header & Search -->
    <top>
        <VBox styleClass="header-section" spacing="15">
            <padding>
                <Insets top="20" right="30" bottom="20" left="30" />
            </padding>
            
            <!-- Header with Title and Actions -->
            <HBox alignment="CENTER_LEFT" spacing="15">
                <ImageView fitHeight="40" fitWidth="40">
                    <Image url="@../images/product-icon.png" />
                </ImageView>
                <Label text="Product Management" styleClass="header-title" />
                <Region HBox.hgrow="ALWAYS" />
                
                <!-- User Info -->
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Label text="Admin" styleClass="user-name" />
                    <Button styleClass="icon-button">
                        <graphic>
                            <ImageView fitHeight="20" fitWidth="20">
                                <Image url="@../images/logout-icon.png" />
                            </ImageView>
                        </graphic>
                    </Button>
                </HBox>
            </HBox>
            
            <!-- Search Bar and Filters -->
            <HBox spacing="15" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Search products..." HBox.hgrow="ALWAYS" styleClass="search-field">
                    <HBox.margin>
                        <Insets right="10" />
                    </HBox.margin>
                </TextField>
                
                <ComboBox fx:id="categoryFilter" promptText="All Categories" styleClass="filter-combo" prefWidth="150" />
                
                <ComboBox fx:id="statusFilter" promptText="All Status" styleClass="filter-combo" prefWidth="120">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="All Status" />
                            <String fx:value="Available" />
                            <String fx:value="Out of Stock" />
                            <String fx:value="Discontinued" />
                        </FXCollections>
                    </items>
                </ComboBox>
                
                <Button fx:id="refreshBtn" text="Refresh" styleClass="secondary-button" />
            </HBox>
        </VBox>
    </top>
    
    <!-- Center - Main Content -->
    <center>
        <SplitPane dividerPositions="0.7" orientation="HORIZONTAL">
            
            <!-- Left Side - Product Table -->
            <VBox spacing="10" styleClass="content-section">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20" />
                </padding>
                
                <!-- Action Buttons -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button fx:id="addBtn" text="Add Product" styleClass="primary-button" />
                    <Button fx:id="editBtn" text="Edit" styleClass="secondary-button" />
                    <Button fx:id="deleteBtn" text="Delete" styleClass="danger-button" />
                    <Button fx:id="exportBtn" text="Export" styleClass="secondary-button">
                        <graphic>
                            <ImageView fitHeight="16" fitWidth="16">
                                <Image url="@../images/export-icon.png" />
                            </ImageView>
                        </graphic>
                    </Button>
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="totalProductsLabel" text="Total: 0 products" styleClass="total-label" />
                </HBox>
                
                <!-- Product Table -->
                <TableView fx:id="productTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idColumn" text="ID" prefWidth="50" />
                        <TableColumn fx:id="nameColumn" text="Product Name" prefWidth="200" />
                        <TableColumn fx:id="categoryColumn" text="Category" prefWidth="120" />
                        <TableColumn fx:id="priceColumn" text="Unit Price" prefWidth="100" />
                        <TableColumn fx:id="unitColumn" text="Unit" prefWidth="80" />
                        <TableColumn fx:id="quantityColumn" text="Stock" prefWidth="80" />
                        <TableColumn fx:id="statusColumn" text="Status" prefWidth="100" />
                        <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="100" />
                    </columns>
                </TableView>
                
                <!-- Pagination -->
                <HBox alignment="CENTER" spacing="10">
                    <Pagination fx:id="pagination" pageCount="10" maxWidth="500" />
                </HBox>
            </VBox>
            
            <!-- Right Side - Product Details & Statistics -->
            <VBox spacing="20" styleClass="details-section">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20" />
                </padding>
                
                <!-- Product Statistics -->
                <VBox spacing="15" styleClass="stats-container">
                    <Label text="Quick Statistics" styleClass="section-title" />
                    
                    <GridPane hgap="15" vgap="15">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50" />
                            <ColumnConstraints percentWidth="50" />
                        </columnConstraints>
                        
                        <!-- Total Products -->
                        <VBox spacing="5" styleClass="stat-card" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Total Products" styleClass="stat-label" />
                            <Label fx:id="totalProductsStat" text="0" styleClass="stat-value" />
                        </VBox>
                        
                        <!-- Low Stock -->
                        <VBox spacing="5" styleClass="stat-card warning" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Low Stock" styleClass="stat-label" />
                            <Label fx:id="lowStockStat" text="0" styleClass="stat-value" />
                        </VBox>
                        
                        <!-- Out of Stock -->
                        <VBox spacing="5" styleClass="stat-card danger" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Out of Stock" styleClass="stat-label" />
                            <Label fx:id="outOfStockStat" text="0" styleClass="stat-value" />
                        </VBox>
                        
                        <!-- Categories -->
                        <VBox spacing="5" styleClass="stat-card" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="Categories" styleClass="stat-label" />
                            <Label fx:id="totalCategoriesStat" text="0" styleClass="stat-value" />
                        </VBox>
                    </GridPane>
                </VBox>
                
                <!-- Product Ingredients -->
                <VBox spacing="15" VBox.vgrow="ALWAYS">
                    <Label text="Product Ingredients" styleClass="section-title" />
                    
                    <TableView fx:id="ingredientTable" prefHeight="200">
                        <columns>
                            <TableColumn fx:id="ingNameColumn" text="Ingredient" prefWidth="120" />
                            <TableColumn fx:id="ingEstimateColumn" text="Estimate" prefWidth="80" />
                            <TableColumn fx:id="ingPriceColumn" text="Cost" prefWidth="80" />
                        </columns>
                    </TableView>
                </VBox>
                
                <!-- Recent Products -->
                <VBox spacing="15">
                    <Label text="Recent Products" styleClass="section-title" />
                    <ListView fx:id="recentProductsList" prefHeight="150" styleClass="recent-list" />
                </VBox>
            </VBox>
        </SplitPane>
    </center>
    
    <!-- Bottom - Status Bar -->
    <bottom>
        <HBox styleClass="status-bar" spacing="20">
            <padding>
                <Insets left="30" right="30" top="10" bottom="10" />
            </padding>
            <Label fx:id="statusLabel" text="Ready" styleClass="status-text" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lastUpdateLabel" text="Last updated: Just now" styleClass="status-text" />
        </HBox>
    </bottom>
    
</BorderPane>