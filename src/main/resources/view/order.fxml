<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="my_app.controller.OrderController">

    <top>
        <Label text="ORDER MANAGEMENT" style="-fx-font-size:20; -fx-padding:10"/>
    </top>

    <left>
        <VBox spacing="10" style="-fx-padding:10; -fx-background-color:#2c3e50;">
            <Button text="Order" onAction="#goOrder"/>
            <Button text="Product" onAction="#goProduct"/>
            <Button text="Customer" onAction="#goCustomer"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="10" style="-fx-padding:10">

            <TextField fx:id="txtSearch" promptText="Search customer..."/>
            <Button text="Search" onAction="#handleSearch"/>
            <Button text="Statistic" onAction="#handleStatistic"/>

            <TableView fx:id="table">
                <columns>
                    <TableColumn fx:id="id" text="ID"/>
                    <TableColumn fx:id="customer" text="Customer"/>

                    <TableColumn fx:id="colQuantity" text="Quantity"/>

                    <TableColumn fx:id="date" text="Date"/>
                    <TableColumn fx:id="total" text="Total"/>
                    <TableColumn fx:id="status" text="Status"/>
                </columns>
            </TableView>

            <TextField fx:id="txtOrderId" promptText="ID"/>
            <ComboBox fx:id="cbCustomer" promptText="Select Customer"/>
            <DatePicker fx:id="dpOrderDate" promptText="Select Date"/>
            
            <Label text="Quantity"/>
            <TextField fx:id="txtQuantity" promptText="Enter quantity..."/>
            
            <Label text="Total"/>
            <TextField fx:id="txtTotal" editable="false" promptText="Total price..."/>
            
            <ComboBox fx:id="cbStatus" promptText="Select Status"/>

            <HBox spacing="10">
                <Button text="New" onAction="#handleNew"/>
                <Button text="Add" onAction="#handleAdd"/>
                <Button text="Update" onAction="#handleUpdate"/>
                <Button text="Delete" onAction="#handleDelete"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>